{
  "name": "diallo-pos",
  "version": "1.0.0",
  "description": "Electron wrapper for my web application",
  "main": "main.js",
  "scripts": {
    "start": "node run.js",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.example.diallopos",
    "productName": "DialloPOS",
    "files": [
      "**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
